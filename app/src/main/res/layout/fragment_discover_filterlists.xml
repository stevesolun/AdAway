<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <ProgressBar
        android:id="@+id/filterlistsProgress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:indeterminate="true"
        android:visibility="gone" />

    <EditText
        android:id="@+id/filterlistsSearchEditText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/filter_search_hint"
        android:importantForAutofill="no"
        android:inputType="text"
        android:minHeight="48dp"
        android:padding="8dp" />

    <HorizontalScrollView
        android:id="@+id/tagScrollView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/tagChipGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="4dp"
            app:singleSelection="true"
            app:selectionRequired="true" />

    </HorizontalScrollView>

    <Spinner
        android:id="@+id/languageSpinner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:contentDescription="@string/filterlists_language_filter_description"
        android:minHeight="48dp"
        android:padding="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingTop="2dp"
        android:paddingEnd="8dp"
        android:paddingBottom="2dp">

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/filterlistsCompatibleOnlySwitch"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:checked="false"
            android:minHeight="48dp"
            android:text="@string/filterlists_compatible_only" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/filterlistsShowSubscribedSwitch"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:checked="false"
            android:minHeight="48dp"
            android:text="@string/filterlists_show_subscribed" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingTop="2dp"
        android:paddingEnd="8dp"
        android:paddingBottom="4dp">

        <LinearLayout
            android:id="@+id/filterlistsBulkActionsRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/filterlistsSelectedActionsRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/filterlistsSubscribeVisibleButton"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minHeight="36dp"
                    android:textSize="12sp"
                    android:text="@string/filterlists_subscribe_selected" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/filterlistsRemoveVisibleButton"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minHeight="36dp"
                    android:textSize="12sp"
                    android:text="@string/filterlists_unsubscribe_selected" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/filterlistsAllActionsRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/filterlistsSubscribeAllButton"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minHeight="36dp"
                    android:textSize="12sp"
                    android:text="@string/filterlists_subscribe_all_options" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/filterlistsRemoveAllButton"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minHeight="36dp"
                    android:textSize="12sp"
                    android:text="@string/filterlists_unsubscribe_all_options" />

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/filterlistsCancelBulkButton"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:contentDescription="@string/filterlists_stop_subscribing"
                android:text="@string/button_cancel"
                android:visibility="gone" />

        </LinearLayout>

        <TextView
            android:id="@+id/filterlistsSubscribeAllStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:accessibilityLiveRegion="polite"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:textSize="12sp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/filterlistsLastRunActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="start"
            android:orientation="vertical"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/filterlistsReviewLastRunButton"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filterlists_review_last_run" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/filterlistsRetryLastRunButton"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filterlists_retry_last_run" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/filterlistsReviewUnsupportedButton"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filterlists_review_unsupported" />

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/filterlistsStateContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="20dp"
        android:paddingEnd="24dp"
        android:paddingBottom="20dp"
        android:visibility="gone"
        tools:visibility="visible">

        <TextView
            android:id="@+id/filterlistsStateTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Subtitle1"
            android:textColor="?attr/colorOnSurface"
            tools:text="@string/filterlists_state_no_matches_title" />

        <TextView
            android:id="@+id/filterlistsStateMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Body2"
            android:textColor="?attr/colorOnSurfaceVariant"
            tools:text="@string/filterlists_state_no_matches_message" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/filterlistsStateRetryButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/filterlists_retry"
            android:visibility="gone"
            tools:visibility="visible" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/filterlistsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="80dp" />

</LinearLayout>
