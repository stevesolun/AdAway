<?xml version="1.0" encoding="utf-8"?>
<!--
    AI Filter Suggestion bottom sheet.
    User types a natural language query, taps "Ask", sees suggested categories,
    then taps "Apply" to subscribe the relevant filter lists.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/ai_suggest_title"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/ui_text_primary" />

        <TextView
            android:id="@+id/aiProviderLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/ui_text_secondary"
            android:text="@string/ai_provider_default_claude" />
    </LinearLayout>

    <!-- Query input row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/aiQueryInputLayout"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="@string/ai_suggest_hint"
            android:layout_marginEnd="8dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/aiQueryEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapSentences"
                android:imeOptions="actionDone"
                android:maxLines="2" />

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/aiAskButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ai_suggest_ask_button" />

    </LinearLayout>

    <!-- Progress bar -->
    <ProgressBar
        android:id="@+id/aiProgressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:indeterminate="true"
        android:visibility="gone"
        android:layout_marginBottom="8dp" />

    <!-- Results area (hidden until response received) -->
    <LinearLayout
        android:id="@+id/aiResultsLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Reasoning text -->
        <TextView
            android:id="@+id/aiReasoningText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/ui_text_secondary"
            android:textStyle="italic"
            android:layout_marginBottom="12dp" />

        <!-- Planned actions label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/ai_agent_actions_label"
            android:textSize="13sp"
            android:textColor="@color/ui_text_secondary"
            android:layout_marginBottom="6dp" />

        <!-- Actions container — populated programmatically -->
        <LinearLayout
            android:id="@+id/aiActionsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp" />

        <!-- Execution results (hidden until Execute is tapped) -->
        <TextView
            android:id="@+id/aiSummaryText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/ui_text_secondary"
            android:layout_marginBottom="16dp"
            android:visibility="gone" />

        <!-- Execute button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/aiApplyButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/ai_agent_execute_button" />

    </LinearLayout>

    <!-- Error text -->
    <TextView
        android:id="@+id/aiErrorText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="?attr/colorError"
        android:visibility="gone"
        android:layout_marginTop="8dp" />

</LinearLayout>
